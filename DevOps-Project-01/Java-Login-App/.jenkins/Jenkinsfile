// =====================================================
// Jenkins Pipeline for Java Login Application
// =====================================================
// Pipeline stages:
//   1. Checkout Code
//   2. Build (Maven)
//   3. Unit Tests
//   4. Docker Image Build
//   5. Push to Registry
//   6. Deploy to Kubernetes
// =====================================================
// =====================================================================

pipeline {
    agent any

    environment {
        APP_NAME = 'dptweb'
        APP_VERSION = '1.0'
        DOCKER_REGISTRY = 'your-registry.com'  // Set your Docker registry
        IMAGE_NAME = "${DOCKER_REGISTRY}/${APP_NAME}"
        DOCKERFILE = 'Dockerfile'
    }

    options {
        // Timeout settings
        timeout(time: 1, unit: 'HOURS')
        // Log rotation
        disableConcurrentBuilds()
        // Catch exceptions and continue
        abortAfterFailure()
    }

    stages {
        // =====================================================
        // Stage 1: Checkout Source Code
        // =====================================================
        stage('Checkout') {
            steps {
                echo "📦 Checking out source code..."
                checkout scm
                sh 'echo "Current branch: $GIT_BRANCH"'
            }
        }

        // =====================================================
        // Stage 2: Maven Build
        // =====================================================
        stage('Build') {
            steps {
                echo "🔨 Building application with Maven..."
                sh '''
                    mvn clean package -DskipTests
                    echo "Build completed successfully!"
                '''
            }
        }

        // =====================================================
        // Stage 3: Run Unit Tests
        // =====================================================
        stage('Test') {
            steps {
                echo "🧪 Running unit tests..."
                sh '''
                    mvn test
                    echo "Tests completed!"
                '''
            }
            post {
                success() {
                    echo "✅ All tests passed!"
                }
                failure() {
                    echo "❌ Tests failed! Check the logs."
                }
            }
        }

        // =====================================================
        // Stage 4: Build Docker Image
        // =====================================================
        stage('Build Docker') {
            steps {
                echo "🐳 Building Docker image..."
                sh '''
                    docker build -t ${IMAGE_NAME}:${APP_VERSION} .
                    docker build -t ${IMAGE_NAME}:latest .
                    echo "Docker image built successfully!"
                '''
            }
        }

        // =====================================================
        // Stage 5: Push to Container Registry
        // =====================================================
        stage('Push') {
            when {
                branch 'master', 'main'
            }
            steps {
                echo "📤 Pushing Docker image to registry..."
                sh '''
                    docker tag ${IMAGE_NAME}:${APP_VERSION} ${DOCKER_REGISTRY}/${APP_NAME}:${APP_VERSION}
                    docker push ${DOCKER_REGISTRY}/${APP_NAME}:${APP_VERSION}
                    docker push ${DOCKER_REGISTRY}/${APP_NAME}:latest
                    echo "Docker image pushed successfully!"
                '''
            }
        }

        // =====================================================
        // Stage 6: Deploy to Kubernetes
        // =====================================================
        stage('Deploy') {
            when {
                branch 'master', 'main'
            }
            steps {
                echo "🚀 Deploying to Kubernetes..."
                sh '''
                    # Check if kubectl is configured
                    kubectl config view > /dev/null 2>&1 && echo "✓ kubectl configured" || echo "✗ kubectl not configured"

                    # Create namespace if not exists
                    kubectl create namespace ${KUBE_NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -

                    # Deploy application
                    kubectl apply -f k8s/
                    echo "Deployment completed!"
                '''
            }
        }
    }

    post {
        success() {
            echo "🎉 Build and deployment successful!"
            echo "📦 Image: ${IMAGE_NAME}:${APP_VERSION}"
        }
        failure() {
            echo "💥 Build or deployment failed!"
        }
        aborted() {
            echo "🛑 Build aborted by user"
        }
        never() {
            // Cleanup steps if needed
        }
    }
}
