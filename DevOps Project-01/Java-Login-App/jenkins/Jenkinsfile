// Jenkins Declarative Pipeline for Java Login App

pipeline {
    agent any

    environment {
        APP_NAME = 'dptweb'
        APP_VERSION = '1.0'
        DOCKER_IMAGE = 'dptweb'
        DOCKER_REGISTRY = 'localhost:5000'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "✅ Source code checked out"
            }
        }

        stage('Build') {
            steps {
                sh '''
                    echo "📦 Building application..."
                    ./mvnw clean package -DskipTests
                    ls -la target/
                '''
            }
        }

        stage('Test') {
            steps {
                sh '''
                    echo "🧪 Running tests..."
                    ./mvnw test
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: '**/target/surefire-reports/*', fingerprint: true
                }
            }
        }

        stage('Security Scan') {
            steps {
                sh '''
                    echo "🔒 Running security scan..."
                    # Run Snyk or OWASP dependency check
                '''
            }
        }

        stage('Code Quality') {
            steps {
                sh '''
                    echo "✅ Checking code quality..."
                    # Can add SonarQube scan here
                '''
            }
        }

        stage('Package') {
            steps {
                sh '''
                    echo "📦 Building Docker image..."
                    docker build -t $DOCKER_REGISTRY/$DOCKER_IMAGE:$APP_VERSION \
                        -f Dockerfile \
                        .
                    docker tag $DOCKER_REGISTRY/$DOCKER_IMAGE:$APP_VERSION \
                        $DOCKER_REGISTRY/$DOCKER_IMAGE:latest
                '''
            }
        }

        stage('Push') {
            when {
                branch 'master', 'main'
            }
            steps {
                sh '''
                    echo "🚀 Pushing to registry..."
                    docker push $DOCKER_REGISTRY/$DOCKER_IMAGE:$APP_VERSION
                    docker push $DOCKER_REGISTRY/$DOCKER_IMAGE:latest
                '''
            }
        }

        stage('Deploy to Staging') {
            environment {
                DOCKER_HUB = 'your-dockerhub-username'
            }
            steps {
                sh '''
                    echo "🔄 Deploying to staging..."
                    docker-compose -f docker-compose-staging.yml up -d
                '''
            }
        }

        stage('Deploy to Production') {
            when {
                branch 'master'
            }
            steps {
                sh '''
                    echo "🌍 Deploying to production..."
                    docker-compose -f docker-compose-prod.yml up -d
                '''
            }
        }
    }

    post {
        success {
            echo '🎉 Build and deployment successful!'
        }
        failure {
            echo '❌ Build failed!'
        }
        aborted {
            echo '⏹️ Build was aborted!'
        }
        always {
            cleanWs()
        }
    }
}
